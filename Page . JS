"use client";
import { useState, useEffect } from 'react';
import { useRouter } from 'next/navigation';
import { getCurrentUser, setCurrentUser } from '../lib/store';

export default function Home() {
  const router = useRouter();
  const [name, setName] = useState('');
  const [birthdate, setBirthdate] = useState('');
  const [error, setError] = useState('');

  useEffect(() => {
    const u = getCurrentUser();
    if (u) router.push('/map');
  }, [router]);

  function handleSubmit(e) {
    e.preventDefault();
    if (!name.trim()) { setError('Entre un prénom.'); return; }
    if (!birthdate) { setError('Entre ta date de naissance.'); return; }
    const age = Math.floor((Date.now() - new Date(birthdate).getTime()) / (365.25*24*3600*1000));
    if (age < 18) { setError("Dette est réservé aux 18 ans et plus."); return; }
    const user = { id: crypto.randomUUID(), name: name.trim() };
    setCurrentUser(user);
    router.push('/map');
  }

  return (
    <main className="container">
      <div className="hero">
        <h1>Dette</h1>
        <p className="tagline">Choisis un lieu. Montre-toi. Rencontre.</p>
        <p className="sub">Des rencontres express, sans prise de tête : un lieu, une photo, un message pour te vendre. Les personnes intéressées te font une demande — tu choisis avec qui tu es "en dette".</p>
      </div>
      <form onSubmit={handleSubmit} className="card">
        <label>Prénom
          <input value={name} onChange={(e)=>setName(e.target.value)} placeholder="Ton prénom" />
        </label>
        <label>Date de naissance
          <input type="date" value={birthdate} onChange={(e)=>setBirthdate(e.target.value)} />
        </label>
        {error && <p className="error">{error}</p>}
        <button type="submit">Entrer</button>
        <p className="fineprint">En continuant, tu confirmes avoir 18 ans ou plus. Version démo — les données restent sur cet appareil tant que la base de données n'est pas connectée.</p>
      </form>
    </main>
  );
}
